# Skopiuj ten plik jako `.env` w katalogu głównym projektu.
# Wartości pobierzesz z Firebase Console → Project settings → Your apps → Web app config.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcjonalnie — tylko gdy w projekcie używasz nazwanej bazy zamiast (default)
# VITE_FIREBASE_DATABASE_ID=
